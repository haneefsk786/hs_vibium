# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/
.gemini/
.claude/

# Node.js
node_modules/

# TypeScript build output
dist/

# Go binaries
clicker/bin/
clicker/clicker

# Embedded SKILL.md (copied from skills/vibe-check/ at build time)
clicker/cmd/clicker/SKILL.md

# Platform package binaries (generated by make package-js)
packages/*/bin/
!packages/vibium/bin/

# macOS
.DS_Store

# Test screenshots
screenshots/

# NPM package tarballs
*.tgz

# Java / Gradle
clients/java/build/
clients/java/.gradle/
clients/java/src/main/resources/natives/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
venv/
.eggs/
*.whl

# Python platform package binaries (generated by make package-python)
packages/python/*/src/*/bin/vibium
packages/python/*/src/*/bin/vibium.exe

# LICENSE/NOTICE copies in subdirectories (generated at publish time)
**/LICENSE
**/NOTICE
!/LICENSE
!/NOTICE
